        <messages/>
        <name>Generate Session Summary</name>
        <onclick/>
        <order>100</order>
        <script><![CDATA[var notes = (current.session_notes + '').toLowerCase();

var summary = 'General counseling session completed.';
var recommendation = 'Monitor student progress.';

if (notes.includes('stress') ||
    notes.includes('exam')) {

    summary =
        'Student is experiencing academic stress and performance pressure.';

    recommendation =
        'Schedule follow-up session within 7 days.';
}
else if (notes.includes('anxiety')) {

    summary =
        'Student is showing signs of anxiety requiring additional support.';

    recommendation =
        'Provide coping strategies and counselor follow-up.';
}
else if (notes.includes('sleep')) {

    summary =
        'Student reports sleep-related concerns impacting wellbeing.';

    recommendation =
        'Recommend healthy sleep routine and monitoring.';
}

current.ai_session_summary = summary;
current.followup_recommendation = recommendation;
current.ai_summary_generated = true;

current.update();

gs.addInfoMessage('Session summary generated.');

action.setRedirectURL(current);]]></script>
