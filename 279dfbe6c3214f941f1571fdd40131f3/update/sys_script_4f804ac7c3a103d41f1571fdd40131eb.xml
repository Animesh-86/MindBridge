        <script><![CDATA[(function executeRule(current, previous) {

    var counselor = current.assigned_counselor.getRefRecord();

    if (!counselor.isValidRecord())
        return;

    var count = parseInt(counselor.active_cases || 0, 10);

    counselor.active_cases = Math.max(0, count - 1);

    counselor.update();

