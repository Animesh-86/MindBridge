        <script><![CDATA[(function executeRule(current, previous) {

    var text = (current.emotional_description + "").toLowerCase();

    var crisisKeywords = [
        "suicide",
        "kill myself",
        "end my life",
        "self harm",
        "self-harm",
        "hurt myself",
        "want to die",
        "not worth living"
    ];

    for (var i = 0; i < crisisKeywords.length; i++) {

        if (text.indexOf(crisisKeywords[i]) > -1) {

            current.crisis_flag = true;
            current.urgency = "HIGH";

            break;
        }
    }

})(current, previous);]]></script>
