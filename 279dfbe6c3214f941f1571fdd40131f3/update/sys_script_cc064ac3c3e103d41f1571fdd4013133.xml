        <script><![CDATA[(function executeRule(current, previous) {

    var active = parseInt(current.active_cases || 0, 10);
    var max = parseInt(current.maximum_active_cases || 0, 10);

    var newStatus = (active >= max) ? 'Busy' : 'Available';

    if (current.status != newStatus) {
        current.setWorkflow(false);
        current.status = newStatus;
        current.update();
    }

